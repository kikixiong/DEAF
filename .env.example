# DEAF environment variables. Copy to .env and fill in.
#
# API keys ----------------------------------------------------------------
# OpenRouter — used for GPT-4o-Audio, Gemini 2.5 Flash, Gemini 3 Flash.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SiliconFlow — used for Qwen3-Omni.
# Get one at https://siliconflow.cn (China site) or https://siliconflow.com (international).
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek — used for the LLM-as-Judge step (judge.py).
# Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local-model code directories ---------------------------------------------
# These point to the upstream repos for SALMONN / DeSTA2 / Audio Flamingo 3.
# See docs/models/ for clone commands.
SALMONN_DIR=/path/to/SALMONN
DESTA_DIR=/path/to/DeSTA2
AF3_DIR=/path/to/Audio_Flamingo3

# Local-model weight directories -------------------------------------------
# Point at the directory that holds the downloaded HuggingFace snapshot.
QWEN2_AUDIO_MODEL=/path/to/Qwen2-Audio-7B-Instruct
DESTA2_MODEL=/path/to/DeSTA2-8B-beta
AF3_MODEL=/path/to/audio-flamingo-3

# Default DEAF data root (overridable per-script with --data-dir) -----------
# Layout expected:  $DEAF_DATA_DIR/{audios_EMIS,noisy_speech,SIC_clips}/*.wav
DEAF_DATA_DIR=./data/raw
